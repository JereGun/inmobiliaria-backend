# ============================================================
# INMOBILIARIA API — Variables de entorno
# Copiá este archivo como .env y completá los valores.
# NUNCA subas .env al repositorio.
# ============================================================

# --- Base de datos (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/inmobiliaria_api
DB_USERNAME=postgres
DB_PASSWORD=tu_password_aqui

# --- JWT ---
# Generá un secreto seguro: openssl rand -base64 64
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRATION=86400000

# --- Admin inicial (solo se crea si no existe ningún usuario) ---
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@inmobiliaria.local
BOOTSTRAP_ADMIN_PASSWORD=CambiaEstaPassword123!

# --- Frontend (CORS) ---
FRONTEND_URL=http://localhost:5173

# --- Cron jobs (formato Spring: segundos minutos horas dia mes dia-semana) ---
AUTO_INVOICE_GENERATION_CRON=0 0 9 1 * *
RENTAL_ADJUSTMENT_NOTIFICATION_CRON=0 0 8 * * *
OVERDUE_RENT_NOTIFICATION_CRON=0 5 8 * * *
